        "writers_per_episode": 4
      },
      "d2": {
        "display": "D2",
        "fixed_good_delay": 3,
        "home_node_pool_size": 8,
        "max_rollout_steps": 12,
        "query_ttl_max": 3,
        "query_ttl_min": 2,
        "required_delay_max": 4,
